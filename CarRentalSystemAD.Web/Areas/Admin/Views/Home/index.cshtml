@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1>Admin Dashboard</h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5>Cars</h5>
                <p>Manage all cars in the system.</p>
                <a asp-area="" asp-controller="Cars" asp-action="All" class="btn btn-primary">View Cars</a>
                <a asp-area="" asp-controller="Cars" asp-action="Add" class="btn btn-success">Add Car</a>
            </div>
        </div>
    </div>
</div>