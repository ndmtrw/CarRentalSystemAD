@model CarRentalSystemAD.Services.Models.ReviewFormModel

@{
    ViewData["Title"] = "Add Review";
}

<h1>Add Review</h1>

<form method="post">
    <input asp-for="CarId" type="hidden" />

    <div class="mb-3">
        <label asp-for="Rating" class="form-label"></label>
        <input asp-for="Rating" class="form-control" />
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Review</button>
    <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.CarId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}