@page
@model CarRentalSystemAD.Web.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-1">Create Account</h3>
                <p class="text-center text-muted mb-4">Join Car Rental System today</p>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                    <div class="row mb-3">
                        <div class="col">
                            <label asp-for="Input.FirstName" class="form-label fw-semibold">First Name</label>
                            <input asp-for="Input.FirstName" class="form-control" placeholder="John" autocomplete="given-name" />
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col">
                            <label asp-for="Input.LastName" class="form-label fw-semibold">Last Name</label>
                            <input asp-for="Input.LastName" class="form-control" placeholder="Doe" autocomplete="family-name" />
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold">Email Address</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="john@example.com" autocomplete="username" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold">Password</label>
                        <input asp-for="Input.Password" class="form-control" placeholder="Min. 6 characters" autocomplete="new-password" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Repeat your password" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Register</button>
                </form>

                <hr class="my-3" />
                <p class="text-center mb-0">
                    Already have an account?
                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
